import sys, binascii

csv = sys.argv[1]
rows = []
with open(csv) as f:
    for line in f:
        parts = line.strip().split('\t')
        if len(parts) < 4:  # seq, time, marker, payload
            continue
        seq = int(parts[0])
        payload_hex = parts[3].replace(':','').strip()
        payload = binascii.unhexlify(payload_hex) if payload_hex else b''
        rows.append((seq, payload))

# sort by seq with wraparound awareness (simple: Python's sort on ints is fine unless capture spans multiple wraps)
rows.sort(key=lambda r: r[0])

frames = []
for seq, payload in rows:
    n = len(payload)
    if n == 0:
        # nothing; you may want to record a lost/concealed frame here if expected
        continue
    if n == 2:
        frames.append((seq, payload, True))  # SID
    elif n % 10 == 0:
        for i in range(0, n, 10):
            frames.append((seq, payload[i:i + 10], False))  # speech frames
    else:
        # Unknown sizing; drop or log as corrupted
        continue

# Write outputs
off = 0
with open('frames.bin', 'wb') as fb, open('index.txt', 'w') as fi:
    for (seq, fr, is_sid) in frames:
        fb.write(fr)
        fi.write(f"{seq}\t{off}\t{len(fr)}\t{1 if is_sid else 0}\t0\n")
        off += len(fr)

print("Wrote frames.bin and index.txt")










